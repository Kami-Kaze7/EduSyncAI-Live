<Window x:Class="EduSyncAI.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register - EduSyncAI" Height="600" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    
    <Grid Background="#ECF0F1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40">
                <TextBlock Text="Create Account" FontSize="28" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="Select your role and fill in your details" Foreground="#7F8C8D" Margin="0,0,0,30"/>
                
                <!-- Role Selection -->
                <TextBlock Text="I am a:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <RadioButton x:Name="LecturerRadio" Content="👨‍🏫 Lecturer" FontSize="16" Margin="0,0,30,0" IsChecked="True"/>
                    <RadioButton x:Name="StudentRadio" Content="👨‍🎓 Student" FontSize="16"/>
                </StackPanel>
                
                <!-- Common Fields -->
                <TextBlock Text="Full Name *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="FullNameBox" Padding="10" FontSize="14" Margin="0,0,0,15"/>
                
                <TextBlock Text="Email *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailBox" Padding="10" FontSize="14" Margin="0,0,0,15"/>
                
                <!-- Lecturer-specific -->
                <StackPanel x:Name="LecturerFields">
                    <TextBlock Text="Username *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="UsernameBox" Padding="10" FontSize="14" Margin="0,0,0,15"/>
                </StackPanel>
                
                <!-- Student-specific -->
                <StackPanel x:Name="StudentFields" Visibility="Collapsed">
                    <TextBlock Text="Matric Number *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="MatricBox" Padding="10" FontSize="14" Margin="0,0,0,15"/>
                    
                    <!-- Face Capture (Required) -->
                    <TextBlock Text="📷 Face Capture (Required for facial recognition) *" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#E74C3C"/>
                    <TextBlock Text="Position your face in the camera and click 'Capture Face'" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,10"/>
                    
                    <!-- Camera Preview -->
                    <Border BorderBrush="#3498DB" BorderThickness="2" Height="250" Width="350" Background="#ECF0F1" CornerRadius="5" Margin="0,0,0,10">
                        <Grid>
                            <Image x:Name="RegistrationCameraPreview" Stretch="Uniform"/>
                            <TextBlock x:Name="CameraPlaceholderText" Text="📷 Camera Preview" FontSize="16" Foreground="#95A5A6" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <!-- Camera Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Button x:Name="StartCameraButton" Content="📷 Start Camera" Click="StartRegistrationCamera_Click" 
                                Background="#27AE60" Foreground="White" Padding="12,6" Margin="5" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="CaptureFaceButton" Content="📸 Capture Face" Click="CaptureFace_Click" 
                                Background="#3498DB" Foreground="White" Padding="12,6" Margin="5" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
                        <Button x:Name="StopCameraButton" Content="⏹ Stop" Click="StopRegistrationCamera_Click" 
                                Background="#E74C3C" Foreground="White" Padding="12,6" Margin="5" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Visibility="Collapsed"/>
                    </StackPanel>
                    
                    <!-- Capture Status -->
                    <TextBlock x:Name="CaptureStatusText" Text="Click 'Start Camera' to begin face capture" 
                              FontSize="11" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    
                    <!-- Captured Preview -->
                    <Border x:Name="CapturedPreviewBorder" BorderBrush="#27AE60" BorderThickness="2" Height="120" Width="160" 
                           Background="#ECF0F1" CornerRadius="5" Visibility="Collapsed" Margin="0,5,0,15">
                        <Grid>
                            <Image x:Name="CapturedFacePreview" Stretch="Uniform"/>
                            <TextBlock Text="✅ Captured" FontSize="12" Foreground="#27AE60" FontWeight="Bold"
                                      HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,3,0,0"/>
                        </Grid>
                    </Border>
                </StackPanel>
                
                <TextBlock Text="Password *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Padding="10" FontSize="14" Margin="0,0,0,15"/>
                
                <TextBlock Text="PIN (4-6 digits, optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="PinBox" Padding="10" FontSize="14" MaxLength="6" Margin="0,0,0,30"/>
                
                <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,15"/>
                
                <Button Content="✓ Create Account" Click="Register_Click"
                        Background="#27AE60" Foreground="White" Padding="20,12" FontSize="16" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,0,10"/>
                
                <Button Content="← Back to Welcome" Click="Back_Click"
                        Background="#95A5A6" Foreground="White" Padding="15,10" FontSize="14"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

<Window x:Class="EduSyncAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EduSyncAI"
        Title="EduSync AI - Lecture Preparation System" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <!-- Window Resources - MUST be defined BEFORE Grid -->
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Navigation Sidebar -->
        <Border Grid.Column="0" Background="#2C3E50" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0">
                    <!-- Header -->
                    <Border Background="#1A252F" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🎓 EduSync AI" FontSize="24" FontWeight="Bold" 
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Lecture Prep System" FontSize="12" 
                                       Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Navigation Buttons -->
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="LECTURER TOOLS" FontSize="11" FontWeight="Bold" 
                                   Foreground="#95A5A6" Margin="15,0,0,10"/>
                        
                        <Button Content="🎬 Class Sessions" 
                                Command="{Binding ShowSessionManagementCommand}"
                                Style="{StaticResource NavButtonStyle}"/>
                        
                        <Button Content="✓ Attendance" 
                                Command="{Binding ShowAttendanceCommand}"
                                Style="{StaticResource NavButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Logout Button -->
                <Button Grid.Row="1" Content="🚪 Logout" Command="{Binding LogoutCommand}"
                        Background="#E74C3C" Foreground="White" Margin="15" Padding="15,10"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
            </Grid>
        </Border>
        
        <!-- Content Area -->
        <Border Grid.Column="1" Background="#ECF0F1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Top Bar -->
                <Border Grid.Row="0" Background="White" Padding="20,15" 
                        BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding CurrentViewName}" FontSize="20" FontWeight="SemiBold"/>
                </Border>
                
                <!-- Dynamic Content -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentView}">
                    <ContentControl.Resources>
                        <!-- Data Templates for ViewModels -->
                        <DataTemplate DataType="{x:Type local:SessionManagementViewModel}">
                            <local:SessionManagementView/>
                        </DataTemplate>
                        
                        <DataTemplate DataType="{x:Type local:AttendanceViewModel}">
                            <local:AttendanceView/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>
        </Border>
    </Grid>
</Window>

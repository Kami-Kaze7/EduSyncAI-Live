<Window x:Class="EduSyncAI.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to EduSyncAI" Height="500" Width="700"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    
    <Grid Background="#2C3E50">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="📚 EduSyncAI" FontSize="48" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <TextBlock Text="Smart Class Session Management" FontSize="18" 
                       Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,0,0,60"/>
            

            <Button Content="🔑 Login to Existing Account" Click="Login_Click"
                    Background="#27AE60" Foreground="White" Padding="40,20" FontSize="18" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Width="350"/>
        </StackPanel>
    </Grid>
</Window>

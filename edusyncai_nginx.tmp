
# HTTPS for nip.io domain (EduSync AI)
server {
    listen 443 ssl;
    server_name 173-212-248-253.nip.io;

    ssl_certificate /etc/letsencrypt/live/173-212-248-253.nip.io/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/173-212-248-253.nip.io/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 200M;

    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    location /api {
        proxy_pass http://localhost:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }
}

# HTTP for nip.io + direct IP (redirect to HTTPS for nip.io, serve directly for IP)
server {
    listen 80;
    server_name 173-212-248-253.nip.io;
    return 301 https://$host$request_uri;
}

server {
    listen 80;
    server_name 173.212.248.253;

    location / {

<UserControl x:Class="EduSyncAI.SessionManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EduSyncAI">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            
            <!-- Active Session Panel -->
            <Border Background="#E74C3C" Padding="20" CornerRadius="5" Margin="0,0,0,20"
                    Visibility="{Binding HasActiveSession, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔴 LIVE SESSION" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <Border x:Name="RecIndicatorBorder" Background="#8B0000" CornerRadius="4" Padding="8,3" Margin="15,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="RecDot" Width="8" Height="8" Fill="White" Margin="0,0,5,0"/>
                                <TextBlock x:Name="RecStatusText" Text="RECORDING" Foreground="White" FontWeight="Bold" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding ActiveSession.CourseName}" FontSize="14" Foreground="White" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding ActiveSession.LectureTopic}" FontSize="12" Foreground="#FFE0E0" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding SessionDuration}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,10,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="📝 Open Whiteboard" Click="OpenWhiteboard_Click"
                                Background="#9B59B6" Foreground="White" Padding="15,10" FontSize="14" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                        <Button x:Name="GoLiveBtn" Content="📡 Go Live" Click="GoLive_Click"
                                Background="#2ECC71" Foreground="White" Padding="15,10" FontSize="14" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                        <Button x:Name="StopLiveBtn" Content="🔴 Stop Broadcast" Click="StopLive_Click"
                                Background="#E67E22" Foreground="White" Padding="15,10" FontSize="14" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" Visibility="Collapsed"/>
                        <Button Content="⏹ End Session" Command="{Binding EndSessionCommand}" 
                            Background="#C0392B" Foreground="White" Padding="15,10" FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Create New Session -->
            <Border Background="White" Padding="20" CornerRadius="5" Margin="0,0,0,20"
                    BorderBrush="#BDC3C7" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Create New Session" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Select Course:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Courses}" SelectedItem="{Binding SelectedCourse}"
                              DisplayMemberPath="CourseTitle" Padding="10" FontSize="14" Margin="0,0,0,20"/>
                    
                    <Button Content="▶️ Start Session" Command="{Binding StartSessionCommand}"
                            Background="#3498DB" Foreground="White" Padding="25,15" FontSize="16" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
            
            <!-- Facial Recognition Panel -->
            <Border Background="White" Padding="20" CornerRadius="5" Margin="0,0,0,20"
                    BorderBrush="#BDC3C7" BorderThickness="1"
                    Visibility="{Binding HasActiveSession, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="📷 Facial Recognition Attendance" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <!-- Camera Preview -->
                    <Border BorderBrush="#3498DB" BorderThickness="2" CornerRadius="5" Margin="0,0,0,15"
                            Height="300" Background="#2C3E50">
                        <Grid>
                            <Image x:Name="CameraPreview" Stretch="Uniform"/>
                            <TextBlock Text="📷 Camera Preview" FontSize="24" Foreground="#95A5A6" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <!-- Controls -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="📷 Start Automatic Recognition" Click="StartCamera_Click"
                                Background="#27AE60" Foreground="White" Padding="20,12" FontSize="14" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                                x:Name="StartButton"/>
                        
                        <Button Content="⏹ Stop Recognition" Click="StopCamera_Click"
                                Background="#E74C3C" Foreground="White" Padding="20,12" FontSize="14" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" Visibility="Collapsed"
                                x:Name="StopButton"/>
                    </StackPanel>
                    
                    <!-- Status Message -->
                    <TextBlock x:Name="FacialStatusText" Text="Click 'Start Automatic Recognition' to begin. Students will be automatically marked present when recognized." 
                              FontSize="14" Foreground="#7F8C8D" Margin="0,0,0,15" TextWrapping="Wrap"/>
                    
                    <!-- Recognized Students -->
                    <Border x:Name="RecognizedStudentsPanel" Background="#ECF0F1" Padding="15" CornerRadius="5" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="✅ Recognized Students" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel x:Name="RecognizedStudentsList"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Live Classroom Panel (hidden until Go Live is clicked) -->
            <local:LiveClassroomPanel x:Name="LivePanel" Visibility="Collapsed" Height="500" Margin="0,0,0,20"/>
            
            <!-- Session History -->
            <Border Background="White" Padding="20" CornerRadius="5"
                    BorderBrush="#BDC3C7" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Session History" FontSize="18" FontWeight="Bold"/>
                        <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                                Background="#95A5A6" Foreground="White" Padding="10,5" FontSize="12"
                                BorderThickness="0" Cursor="Hand" Margin="15,0,0,0"/>
                    </StackPanel>
                    
                    <DataGrid ItemsSource="{Binding SessionHistory}" AutoGenerateColumns="False"
                              IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowBackground="White" AlternatingRowBackground="#F8F9FA">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Course" Binding="{Binding CourseName}" Width="*"/>
                            <DataGridTextColumn Header="Lecture" Binding="{Binding LectureTopic}" Width="*"/>
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="80"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat='{}{0:MM/dd HH:mm}'}" Width="100"/>
                            <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="EduSyncAI.CourseManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <TextBlock Text="📚 Course Management" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- Create Course Form -->
            <Border Background="#F5F5F5" Padding="20" CornerRadius="8" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Create New Course" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Course Code" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding CourseCode, UpdateSourceTrigger=PropertyChanged}" 
                             Height="35" FontSize="14" Padding="8"/>
                    
                    <TextBlock Text="Course Title" FontWeight="SemiBold" Margin="0,15,0,5"/>
                    <TextBox Text="{Binding CourseTitle, UpdateSourceTrigger=PropertyChanged}" 
                             Height="35" FontSize="14" Padding="8"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <Button Content="📄 Upload Syllabus" 
                                Command="{Binding UploadSyllabusCommand}"
                                Background="#2196F3" Foreground="White"
                                Padding="15,10" FontSize="14" Cursor="Hand" Margin="0,0,10,0"/>
                        
                        <Button Content="➕ Create Course" 
                                Command="{Binding CreateCourseCommand}"
                                Background="#4CAF50" Foreground="White"
                                Padding="15,10" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
                    </StackPanel>
                    
                    <TextBlock Text="{Binding SyllabusPath}" Margin="0,10,0,0" 
                               FontStyle="Italic" Foreground="#666" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            
            <!-- Existing Courses List -->
            <TextBlock Text="Existing Courses" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding Courses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" BorderBrush="#DDD" BorderThickness="1" 
                                Padding="15" Margin="0,0,0,10" CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="{Binding CourseCode}" FontWeight="Bold" 
                                           FontSize="16" Grid.Column="0" Margin="0,0,15,0" 
                                           Foreground="#4CAF50"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding CourseTitle}" FontSize="14"/>
                                    <TextBlock Text="{Binding SyllabusPath, StringFormat='Syllabus: {0}'}" 
                                               FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>

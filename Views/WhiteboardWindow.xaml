<Window x:Class="EduSyncAI.WhiteboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EduSyncAI"
        Title="Interactive Whiteboard" 
        Height="800" Width="1200"
        WindowState="Maximized"
        Background="#F5F5F5">
    
    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="ActiveToolButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style x:Key="ColorButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Session Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#34495E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active Sidebar Button -->
        <Style x:Key="ActiveSidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Session Sidebar -->
            <ColumnDefinition Width="60"/>
            <!-- Main Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== SESSION SIDEBAR ==================== -->
        <Border Grid.Column="0" Background="#1A252F">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Session Timer / Logo -->
                <StackPanel Grid.Row="0" Margin="0,12,0,10">
                    <TextBlock Text="🎓" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SidebarTimerText" Text="00:00" FontSize="11" FontWeight="Bold" 
                               Foreground="#3b82f6" HorizontalAlignment="Center"/>
                    <!-- Recording Indicator -->
                    <Border x:Name="SidebarRecBorder" Background="#8B0000" CornerRadius="3" 
                            Padding="4,2" Margin="8,6,8,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse x:Name="SidebarRecDot" Width="6" Height="6" Fill="White" Margin="0,0,3,0"/>
                            <TextBlock Text="REC" Foreground="White" FontSize="9" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Sidebar Buttons -->
                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <!-- Go Live -->
                    <Button x:Name="SidebarGoLiveBtn" Click="SidebarGoLive_Click" 
                            Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📡" FontSize="22" HorizontalAlignment="Center"/>
                            <TextBlock Text="Live" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Facial Recognition Attendance -->
                    <Button x:Name="SidebarAttendanceBtn" Click="SidebarAttendance_Click"
                            Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📷" FontSize="22" HorizontalAlignment="Center"/>
                            <TextBlock Text="Attend" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- End Session -->
                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                    <Button x:Name="SidebarEndSessionBtn" Click="SidebarEndSession_Click"
                            Cursor="Hand" Padding="8,10"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="EndBorder" Background="{TemplateBinding Background}" 
                                        Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="6,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="⏹" FontSize="22" HorizontalAlignment="Center" Foreground="#E74C3C"/>
                                        <TextBlock Text="End" FontSize="9" HorizontalAlignment="Center" 
                                                   Foreground="#E74C3C" Margin="0,2,0,0" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="EndBorder" Property="Background" Value="#3a1a1a"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== MAIN CONTENT AREA ==================== -->
        <Grid Grid.Column="1">
            <!-- Layer 0: Whiteboard (always visible) -->
            <DockPanel>
                <!-- Top Toolbar -->
                <Border DockPanel.Dock="Top" Background="White" Padding="10,8" 
                        BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            
                            <!-- Drawing Tools -->
                            <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                                <TextBlock Text="TOOLS" FontSize="10" Foreground="#95A5A6" FontWeight="Bold" Margin="4,0,0,4"/>
                                <Border Background="#F8F9FA" BorderBrush="#E0E6ED" BorderThickness="1" CornerRadius="6" Padding="4">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="PenButton" Content="🖊️ Pen" Click="PenButton_Click" Style="{StaticResource ActiveToolButtonStyle}"/>
                                        <Button x:Name="HighlighterButton" Content="🖍️ Highlighter" Click="HighlighterButton_Click" Style="{StaticResource ToolButtonStyle}"/>
                                        <Button x:Name="EraserButton" Content="🧽 Eraser" Click="EraserButton_Click" Style="{StaticResource ToolButtonStyle}"/>
                                        <Button x:Name="SelectButton" Content="✋ Select" Click="SelectButton_Click" Style="{StaticResource ToolButtonStyle}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <!-- Shapes Tools -->
                            <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                                <TextBlock Text="SHAPES" FontSize="10" Foreground="#95A5A6" FontWeight="Bold" Margin="4,0,0,4"/>
                                <Border Background="#F8F9FA" BorderBrush="#E0E6ED" BorderThickness="1" CornerRadius="6" Padding="4">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="RectangleButton" Content="▭" Click="RectangleButton_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Rectangle" Width="36"/>
                                        <Button x:Name="CircleButton" Content="○" Click="CircleButton_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Circle" Width="36"/>
                                        <Button x:Name="LineButton" Content="─" Click="LineButton_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Line" Width="36"/>
                                        <Button x:Name="ArrowButton" Content="→" Click="ArrowButton_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Arrow" Width="36"/>
                                        <Button x:Name="TriangleButton" Content="△" Click="TriangleButton_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Triangle" Width="36"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Insert Tools -->
                            <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                                <TextBlock Text="INSERT" FontSize="10" Foreground="#95A5A6" FontWeight="Bold" Margin="4,0,0,4"/>
                                <Border Background="#F8F9FA" BorderBrush="#E0E6ED" BorderThickness="1" CornerRadius="6" Padding="4">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="ImageButton" Content="🖼️ Image" Click="ImageButton_Click" Style="{StaticResource ToolButtonStyle}" Background="#16A085" Foreground="White" BorderThickness="0"/>
                                        <Button x:Name="DocumentButton" Content="📄 Document" Click="DocumentButton_Click" Style="{StaticResource ToolButtonStyle}" Background="#2980B9" Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <!-- Properties -->
                            <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                                <TextBlock Text="THICKNESS" FontSize="10" Foreground="#95A5A6" FontWeight="Bold" Margin="4,0,0,4"/>
                                <Border Background="#F8F9FA" BorderBrush="#E0E6ED" BorderThickness="1" CornerRadius="6" Padding="6">
                                    <ComboBox x:Name="ThicknessComboBox" Width="110" Height="28" SelectionChanged="ThicknessComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Thin (2px)" Tag="2"/>
                                        <ComboBoxItem Content="Medium (5px)" Tag="5" IsSelected="True"/>
                                        <ComboBoxItem Content="Thick (10px)" Tag="10"/>
                                        <ComboBoxItem Content="Very Thick (15px)" Tag="15"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>

                            <!-- Colors -->
                            <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                                <TextBlock Text="COLORS" FontSize="10" Foreground="#95A5A6" FontWeight="Bold" Margin="4,0,0,4"/>
                                <Border Background="#F8F9FA" BorderBrush="#E0E6ED" BorderThickness="1" CornerRadius="6" Padding="4">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Background="Black" Click="ColorButton_Click" Tag="Black" Style="{StaticResource ColorButtonStyle}" BorderBrush="#3498DB" BorderThickness="3"/>
                                        <Button Background="Red" Click="ColorButton_Click" Tag="Red" Style="{StaticResource ColorButtonStyle}"/>
                                        <Button Background="Blue" Click="ColorButton_Click" Tag="Blue" Style="{StaticResource ColorButtonStyle}"/>
                                        <Button Background="Green" Click="ColorButton_Click" Tag="Green" Style="{StaticResource ColorButtonStyle}"/>
                                        <Button Background="Yellow" Click="ColorButton_Click" Tag="Yellow" Style="{StaticResource ColorButtonStyle}"/>
                                        <Button Background="Orange" Click="ColorButton_Click" Tag="Orange" Style="{StaticResource ColorButtonStyle}"/>
                                        <Button Background="Purple" Click="ColorButton_Click" Tag="Purple" Style="{StaticResource ColorButtonStyle}"/>
                                        <Button Background="Brown" Click="ColorButton_Click" Tag="Brown" Style="{StaticResource ColorButtonStyle}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Actions -->
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="ACTIONS" FontSize="10" Foreground="#95A5A6" FontWeight="Bold" Margin="4,0,0,4"/>
                                <Border Background="#F8F9FA" BorderBrush="#E0E6ED" BorderThickness="1" CornerRadius="6" Padding="4">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="🗑️ Clear" Click="ClearButton_Click" Style="{StaticResource ToolButtonStyle}" Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                                        <Button Content="💾 Save" Click="SaveButton_Click" Style="{StaticResource ToolButtonStyle}" Background="#27AE60" Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                
                <!-- Document Page Navigation Bar -->
                <Border x:Name="DocNavBar" DockPanel.Dock="Bottom" Background="#2C3E50" Padding="10,8" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="📄" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="DocNameText" Text="document.pdf" Foreground="White" FontSize="13" VerticalAlignment="Center" MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="PrevPageBtn" Content="◀ Previous" Click="PrevPage_Click" 
                                    Background="#34495E" Foreground="White" BorderThickness="0" Padding="12,6" Margin="4" Cursor="Hand">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                            </Button>
                            <TextBlock x:Name="PageIndicator" Text="Page 1 of 1" Foreground="White" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="16,0"/>
                            <Button x:Name="NextPageBtn" Content="Next ▶" Click="NextPage_Click" 
                                    Background="#34495E" Foreground="White" BorderThickness="0" Padding="12,6" Margin="4" Cursor="Hand">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                            </Button>
                        </StackPanel>
                        
                        <Button Grid.Column="2" Content="✕ Close Document" Click="CloseDocument_Click" 
                                Background="#E74C3C" Foreground="White" BorderThickness="0" Padding="12,6" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                        </Button>
                    </Grid>
                </Border>

                <!-- Main Whiteboard Canvas with Zoom Support -->
                <ScrollViewer x:Name="WhiteboardScrollViewer" 
                              HorizontalScrollBarVisibility="Auto" 
                              VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="WhiteboardScrollViewer_PreviewMouseWheel"
                              IsManipulationEnabled="True"
                              ManipulationDelta="WhiteboardScrollViewer_ManipulationDelta">
                    <Border Background="White" Margin="10" CornerRadius="5" 
                            BorderBrush="#BDC3C7" BorderThickness="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border.LayoutTransform>
                            <ScaleTransform x:Name="CanvasScale" ScaleX="1.0" ScaleY="1.0" />
                        </Border.LayoutTransform>
                        <InkCanvas x:Name="WhiteboardCanvas" 
                                  Background="White"
                                  Width="1920" Height="1080"
                                  MouseDown="WhiteboardCanvas_MouseDown"
                                  MouseMove="WhiteboardCanvas_MouseMove"
                                  MouseUp="WhiteboardCanvas_MouseUp"/>
                    </Border>
                </ScrollViewer>
            </DockPanel>

            <!-- ==================== OVERLAY PANELS ==================== -->
            
            <!-- Layer 1: Semi-transparent overlay backdrop (click to dismiss) -->
            <Border x:Name="OverlayBackdrop" Background="#40000000" Visibility="Collapsed"
                    MouseDown="OverlayBackdrop_MouseDown"/>

            <!-- Layer 2: Overlay Panel Container (right side) -->
            <Border x:Name="OverlayPanel" Visibility="Collapsed" 
                    HorizontalAlignment="Right" VerticalAlignment="Stretch"
                    Width="500" Margin="0,0,10,10">
                <Border Background="White" CornerRadius="10" 
                        BorderBrush="#3498DB" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Overlay Header -->
                        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10"
                                CornerRadius="10,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="OverlayTitle" Text="Panel" FontSize="16" 
                                           FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="➖" Click="MinimizeOverlay_Click" 
                                            Background="Transparent" Foreground="White" 
                                            BorderThickness="0" Cursor="Hand" FontSize="14" Padding="8,4"
                                            ToolTip="Minimize"/>
                                    <Button Content="✕" Click="CloseOverlay_Click" 
                                            Background="Transparent" Foreground="#E74C3C" 
                                            BorderThickness="0" Cursor="Hand" FontSize="16" Padding="8,4" FontWeight="Bold"
                                            ToolTip="Close"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Overlay Content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Grid x:Name="OverlayContent" Margin="15"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Border>

            <!-- ==================== LIVE CLASSROOM OVERLAY ==================== -->
            <Border x:Name="LiveOverlayPanel" Visibility="Collapsed" 
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Margin="10,50,10,10">
                <Border Background="White" CornerRadius="10" 
                        BorderBrush="#FF4444" BorderThickness="2">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Live Header -->
                        <Border Grid.Row="0" Background="#1a1a2e" Padding="15,10"
                                CornerRadius="10,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="#FF4444" Margin="0,0,8,0"/>
                                    <TextBlock Text="LIVE BROADCAST" FontSize="16" 
                                               FontWeight="Bold" Foreground="#FF4444" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LiveAttendanceStatusText" 
                                               Text="  |  📷 Auto-attendance active" 
                                               FontSize="12" Foreground="#27AE60" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="➖" Click="MinimizeLiveOverlay_Click" 
                                            Background="Transparent" Foreground="White" 
                                            BorderThickness="0" Cursor="Hand" FontSize="14" Padding="8,4"
                                            ToolTip="Minimize"/>
                                    <Button Content="🔴 Stop" Click="StopLiveOverlay_Click" 
                                            Background="#FF4444" Foreground="White" 
                                            BorderThickness="0" Cursor="Hand" FontSize="12" Padding="10,6" FontWeight="Bold"
                                            ToolTip="Stop Broadcast">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Live Content (LiveClassroomPanel) -->
                        <local:LiveClassroomPanel Grid.Row="1" x:Name="LivePanel"/>
                    </Grid>
                </Border>
            </Border>

            <!-- ==================== PiP CAMERA OVERLAY ==================== -->
            <Border x:Name="PipOverlay" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Width="260" Height="200" Margin="0,0,20,20">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="PipTranslate" X="0" Y="0"/>
                </Border.RenderTransform>
                <Border Background="#1a1a2e" CornerRadius="10" 
                        BorderBrush="#FF4444" BorderThickness="2">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- PiP Header (draggable) -->
                        <Border Grid.Row="0" Background="#2d2d44" Padding="8,4"
                                CornerRadius="10,10,0,0" Cursor="SizeAll"
                                MouseLeftButtonDown="PipHeader_MouseDown"
                                MouseMove="PipHeader_MouseMove"
                                MouseLeftButtonUp="PipHeader_MouseUp">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#FF4444" Margin="0,0,6,0"/>
                                    <TextBlock Text="🎥 You (Live)" FontSize="11" 
                                               FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="✕" Click="ClosePip_Click" 
                                        Background="Transparent" Foreground="#888" 
                                        BorderThickness="0" Cursor="Hand" FontSize="12" Padding="6,2"
                                        ToolTip="Hide PiP"/>
                            </Grid>
                        </Border>

                        <!-- PiP Camera Feed -->
                        <Border Grid.Row="1" Background="#1a1a2e">
                            <Image x:Name="PipCameraImage" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="LowQuality"/>
                        </Border>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>

<Window x:Class="EduSyncAI.WhiteboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Interactive Whiteboard" 
        Height="800" Width="1200"
        WindowState="Maximized"
        Background="#F5F5F5"
        Icon="/edusync_icon.ico">
    
    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="ActiveToolButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style x:Key="ColorButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <DockPanel>
        <!-- Top Toolbar -->
        <Border DockPanel.Dock="Top" Background="White" Padding="10" 
                BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Drawing Tools -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Tools:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button x:Name="PenButton" Content="🖊️ Pen" Click="PenButton_Click" Style="{StaticResource ActiveToolButtonStyle}"/>
                    <Button x:Name="HighlighterButton" Content="🖍️ Highlighter" Click="HighlighterButton_Click" Style="{StaticResource ToolButtonStyle}"/>
                    <Button x:Name="EraserButton" Content="🧽 Eraser" Click="EraserButton_Click" Style="{StaticResource ToolButtonStyle}"/>
                    <Button x:Name="SelectButton" Content="✋ Select" Click="SelectButton_Click" Style="{StaticResource ToolButtonStyle}"/>
                    
                    <Separator Margin="10,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                    
                    <!-- Shapes Tools -->
                    <TextBlock Text="Shapes:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Button x:Name="RectangleButton" Content="▭" Click="RectangleButton_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Rectangle" Width="40"/>
                    <Button x:Name="CircleButton" Content="○" Click="CircleButton_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Circle" Width="40"/>
                    <Button x:Name="LineButton" Content="─" Click="LineButton_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Line" Width="40"/>
                    <Button x:Name="ArrowButton" Content="→" Click="ArrowButton_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Arrow" Width="40"/>
                    <Button x:Name="TriangleButton" Content="△" Click="TriangleButton_Click" Style="{StaticResource ToolButtonStyle}" ToolTip="Triangle" Width="40"/>
                    
                    <Separator Margin="10,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                    
                    <!-- Image & Document Tools -->
                    <Button x:Name="ImageButton" Content="🖼️ Image" Click="ImageButton_Click" Style="{StaticResource ToolButtonStyle}" Background="#16A085" Foreground="White"/>
                    <Button x:Name="DocumentButton" Content="📄 Document" Click="DocumentButton_Click" Style="{StaticResource ToolButtonStyle}" Background="#2980B9" Foreground="White" ToolTip="Open PDF or Word document"/>
                    
                    <Separator Margin="10,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                    
                    <!-- Thickness -->
                    <TextBlock Text="Size:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <ComboBox x:Name="ThicknessComboBox" Width="100" SelectionChanged="ThicknessComboBox_SelectionChanged">
                        <ComboBoxItem Content="Thin (2px)" Tag="2"/>
                        <ComboBoxItem Content="Medium (5px)" Tag="5" IsSelected="True"/>
                        <ComboBoxItem Content="Thick (10px)" Tag="10"/>
                        <ComboBoxItem Content="Very Thick (15px)" Tag="15"/>
                    </ComboBox>
                </StackPanel>
                
                <!-- Colors -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Colors:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Background="Black" Click="ColorButton_Click" Tag="Black" Style="{StaticResource ColorButtonStyle}" BorderBrush="#3498DB" BorderThickness="3"/>
                    <Button Background="Red" Click="ColorButton_Click" Tag="Red" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="Blue" Click="ColorButton_Click" Tag="Blue" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="Green" Click="ColorButton_Click" Tag="Green" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="Yellow" Click="ColorButton_Click" Tag="Yellow" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="Orange" Click="ColorButton_Click" Tag="Orange" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="Purple" Click="ColorButton_Click" Tag="Purple" Style="{StaticResource ColorButtonStyle}"/>
                    <Button Background="Brown" Click="ColorButton_Click" Tag="Brown" Style="{StaticResource ColorButtonStyle}"/>
                </StackPanel>
                
                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="🗑️ Clear All" Click="ClearButton_Click" Style="{StaticResource ToolButtonStyle}" Background="#E74C3C" Foreground="White"/>
                    <Button Content="💾 Save" Click="SaveButton_Click" Style="{StaticResource ToolButtonStyle}" Background="#27AE60" Foreground="White"/>
                    <Button Content="❌ Close" Click="CloseButton_Click" Style="{StaticResource ToolButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Document Page Navigation Bar -->
        <Border x:Name="DocNavBar" DockPanel.Dock="Bottom" Background="#2C3E50" Padding="10,8" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📄" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="DocNameText" Text="document.pdf" Foreground="White" FontSize="13" VerticalAlignment="Center" MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="PrevPageBtn" Content="◀ Previous" Click="PrevPage_Click" 
                            Background="#34495E" Foreground="White" BorderThickness="0" Padding="12,6" Margin="4" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                    </Button>
                    <TextBlock x:Name="PageIndicator" Text="Page 1 of 1" Foreground="White" 
                               FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="16,0"/>
                    <Button x:Name="NextPageBtn" Content="Next ▶" Click="NextPage_Click" 
                            Background="#34495E" Foreground="White" BorderThickness="0" Padding="12,6" Margin="4" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
                
                <Button Grid.Column="2" Content="✕ Close Document" Click="CloseDocument_Click" 
                        Background="#E74C3C" Foreground="White" BorderThickness="0" Padding="12,6" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Main Whiteboard Canvas -->
        <Border Background="White" Margin="10" CornerRadius="5" 
                BorderBrush="#BDC3C7" BorderThickness="1">
            <InkCanvas x:Name="WhiteboardCanvas" 
                      Background="White"
                      MouseDown="WhiteboardCanvas_MouseDown"
                      MouseMove="WhiteboardCanvas_MouseMove"
                      MouseUp="WhiteboardCanvas_MouseUp"/>
        </Border>
    </DockPanel>
</Window>

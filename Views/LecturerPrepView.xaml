<UserControl x:Class="EduSyncAI.LecturerPrepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <TextBlock Text="✍️ Prepare Lecture" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- Timer Display -->
            <Border Background="#FF5722" Padding="15" CornerRadius="8" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="⏱️ Time Remaining: " Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TimeRemaining}" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    <Button Content="▶️ Start Timer" 
                            Command="{Binding StartTimerCommand}"
                            Background="White" Foreground="#FF5722"
                            Padding="10,5" FontSize="14" Margin="20,0,0,0" Cursor="Hand"/>
                </StackPanel>
            </Border>
            
            <!-- Lecture Selector -->
            <Border Background="#F5F5F5" Padding="20" CornerRadius="8" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Select Lecture" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ComboBox ItemsSource="{Binding AvailableLectures}" 
                              SelectedItem="{Binding SelectedLecture}"
                              DisplayMemberPath="Topic"
                              Height="35" FontSize="14"/>
                </StackPanel>
            </Border>
            
            <!-- Prep Form -->
            <Border Background="White" BorderBrush="#DDD" BorderThickness="1" 
                    Padding="20" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="💡 Core Ideas" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding CoreIdeas, UpdateSourceTrigger=PropertyChanged}" 
                             Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                             FontSize="14" Padding="8" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="🔑 Key Terms" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding KeyTerms, UpdateSourceTrigger=PropertyChanged}" 
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             FontSize="14" Padding="8" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="📝 Simple Example" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SimpleExample, UpdateSourceTrigger=PropertyChanged}" 
                             Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                             FontSize="14" Padding="8" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="👂 What to Listen For" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding WhatToListenFor, UpdateSourceTrigger=PropertyChanged}" 
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             FontSize="14" Padding="8" Margin="0,0,0,20"/>
                    
                    <Button Content="💾 Save &amp; Notify Students"
                            Command="{Binding SaveCommand}"
                            Background="#4CAF50" Foreground="White"
                            Padding="20,12" FontSize="16" FontWeight="Bold" 
                            Cursor="Hand" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

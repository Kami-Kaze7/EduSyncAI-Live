<UserControl x:Class="EduSyncAI.StudentDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EduSyncAI">
    
    <Grid Background="#ECF0F1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <!-- Header -->
                <TextBlock Text="👥 Student Management" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
                
                <!-- Course Selection -->
                <Border Background="White" Padding="20" CornerRadius="5" Margin="0,0,0,20" BorderBrush="#BDC3C7" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Select Course" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ComboBox ItemsSource="{Binding Courses}" SelectedItem="{Binding SelectedCourse}"
                                  DisplayMemberPath="CourseTitle" Padding="10" FontSize="14"/>
                    </StackPanel>
                </Border>

                <!-- Upload Section -->
                <Border Background="White" Padding="20" CornerRadius="5" Margin="0,0,0,20" BorderBrush="#BDC3C7" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📤 Upload Student List" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBlock Text="Upload Excel (.xlsx) or CSV file with columns: MatricNumber, FullName, Email, WindowsUsername (optional)" 
                                   TextWrapping="Wrap" Foreground="#7F8C8D" FontSize="12" Margin="0,0,0,15"/>
                        <Button Content="📁 Choose File and Upload" Command="{Binding UploadExcelCommand}"
                                Background="#3498DB" Foreground="White" Padding="20,12" FontSize="14" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Manual Entry Section -->
                <Border Background="White" Padding="20" CornerRadius="5" Margin="0,0,0,20" BorderBrush="#BDC3C7" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="✍ Add Student Manually" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Matric Number -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                                <TextBlock Text="Matric Number *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding NewMatricNumber, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="10" FontSize="14"/>
                            </StackPanel>

                            <!-- Full Name -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,15">
                                <TextBlock Text="Full Name *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding NewFullName, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="10" FontSize="14"/>
                            </StackPanel>

                            <!-- Email -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                                <TextBlock Text="Email *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding NewEmail, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="10" FontSize="14"/>
                            </StackPanel>

                            <!-- Windows Username -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,15">
                                <TextBlock Text="Windows Username (for fingerprint)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding NewWindowsUsername, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="10" FontSize="14"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="➕ Add Student" Command="{Binding AddStudentCommand}"
                                Background="#27AE60" Foreground="White" Padding="20,12" FontSize="14" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <Border Background="#3498DB" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <!-- Student List -->
                <Border Background="White" Padding="20" CornerRadius="5" BorderBrush="#BDC3C7" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="📋 Enrolled Students" FontSize="16" FontWeight="Bold"/>
                            <Button Content="🔄" Command="{Binding RefreshCommand}"
                                    Background="#95A5A6" Foreground="White" Padding="8,5" FontSize="12"
                                    BorderThickness="0" Cursor="Hand" Margin="15,0,0,0"/>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding Students}" SelectedItem="{Binding SelectedStudent}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" Height="300"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="#F8F9FA">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Matric Number" Binding="{Binding MatricNumber}" Width="120"/>
                                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                                <DataGridTextColumn Header="Windows User" Binding="{Binding WindowsUsername}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Content="🗑 Delete Selected Student" Command="{Binding DeleteStudentCommand}"
                                Background="#E74C3C" Foreground="White" Padding="15,10" FontSize="12" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

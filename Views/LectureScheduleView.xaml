<UserControl x:Class="EduSyncAI.LectureScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <TextBlock Text="📅 Lecture Schedule" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- Course Selector -->
            <Border Background="#F5F5F5" Padding="20" CornerRadius="8" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Select Course" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ComboBox ItemsSource="{Binding Courses}" 
                              SelectedItem="{Binding SelectedCourse}"
                              DisplayMemberPath="CourseTitle"
                              Height="35" FontSize="14"/>
                </StackPanel>
            </Border>
            
            <!-- Add Lecture Form -->
            <Border Background="#E3F2FD" Padding="20" CornerRadius="8" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Add New Lecture" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Lecture Topic" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewLectureTopic, UpdateSourceTrigger=PropertyChanged}" 
                             Height="35" FontSize="14" Padding="8"/>
                    
                    <TextBlock Text="Lecture Date" FontWeight="SemiBold" Margin="0,15,0,5"/>
                    <DatePicker SelectedDate="{Binding NewLectureDate}" 
                                Height="35" FontSize="14"/>
                    
                    <Button Content="➕ Add Lecture" 
                            Command="{Binding AddLectureCommand}"
                            Background="#2196F3" Foreground="White"
                            Padding="15,10" FontSize="14" FontWeight="SemiBold" 
                            Cursor="Hand" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Lectures List -->
            <TextBlock Text="Scheduled Lectures" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding Lectures}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" BorderBrush="#2196F3" BorderThickness="2" 
                                Padding="15" Margin="0,0,0,10" CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Background="#2196F3" Padding="10" CornerRadius="5" 
                                        Grid.Column="0" Margin="0,0,15,0" VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="{Binding LectureDate, StringFormat='MMM'}" 
                                                   Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding LectureDate, StringFormat='dd'}" 
                                                   Foreground="White" FontSize="20" FontWeight="Bold" 
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Topic}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding LectureDate, StringFormat='dddd, MMMM dd, yyyy'}" 
                                               FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>

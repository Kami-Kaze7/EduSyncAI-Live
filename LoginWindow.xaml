<Window x:Class="EduSyncAI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EduSyncAI"
        Title="EduSync AI - Login" 
        Height="600" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <Style x:Key="PinButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Background="#ECF0F1">
        <!-- Header -->
        <Border Background="#2C3E50" Height="100" VerticalAlignment="Top">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🎓 EduSync AI" FontSize="32" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Lecturer Login" FontSize="14" 
                           Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Login Content -->
        <Border Background="White" Margin="30,120,30,30" CornerRadius="10" Padding="30">
            <StackPanel>
                <!-- Error Message -->
                <Border Background="#E74C3C" Padding="15" CornerRadius="5" Margin="0,0,0,20"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <!-- Tab Control -->
                <TabControl SelectedIndex="{Binding SelectedTabIndex}">
                    <!-- PIN Login Tab -->
                    <TabItem Header="PIN Login">
                        <StackPanel Margin="20">
                            <TextBlock Text="Enter your 4-6 digit PIN" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            
                            <!-- PIN Display -->
                            <TextBlock Text="{Binding PinDisplay}" FontSize="36" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Margin="0,0,0,20" MinHeight="50"/>
                            
                            <!-- PIN Keypad -->
                            <UniformGrid Rows="4" Columns="3" Margin="0,0,0,20">
                                <Button Content="1" Command="{Binding AddPinDigitCommand}" CommandParameter="1" Style="{StaticResource PinButtonStyle}"/>
                                <Button Content="2" Command="{Binding AddPinDigitCommand}" CommandParameter="2" Style="{StaticResource PinButtonStyle}"/>
                                <Button Content="3" Command="{Binding AddPinDigitCommand}" CommandParameter="3" Style="{StaticResource PinButtonStyle}"/>
                                <Button Content="4" Command="{Binding AddPinDigitCommand}" CommandParameter="4" Style="{StaticResource PinButtonStyle}"/>
                                <Button Content="5" Command="{Binding AddPinDigitCommand}" CommandParameter="5" Style="{StaticResource PinButtonStyle}"/>
                                <Button Content="6" Command="{Binding AddPinDigitCommand}" CommandParameter="6" Style="{StaticResource PinButtonStyle}"/>
                                <Button Content="7" Command="{Binding AddPinDigitCommand}" CommandParameter="7" Style="{StaticResource PinButtonStyle}"/>
                                <Button Content="8" Command="{Binding AddPinDigitCommand}" CommandParameter="8" Style="{StaticResource PinButtonStyle}"/>
                                <Button Content="9" Command="{Binding AddPinDigitCommand}" CommandParameter="9" Style="{StaticResource PinButtonStyle}"/>
                                <Button Content="Clear" Command="{Binding ClearPinCommand}" Style="{StaticResource PinButtonStyle}" Background="#E74C3C"/>
                                <Button Content="0" Command="{Binding AddPinDigitCommand}" CommandParameter="0" Style="{StaticResource PinButtonStyle}"/>
                                <Button Content="⌫" Command="{Binding BackspacePinCommand}" Style="{StaticResource PinButtonStyle}" Background="#95A5A6"/>
                            </UniformGrid>
                        </StackPanel>
                    </TabItem>

                    <!-- Password Login Tab -->
                    <TabItem Header="Username/Password">
                        <StackPanel Margin="20">
                            <TextBlock Text="Username:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Username}" Padding="10" FontSize="14" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Password:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="PasswordBox" Padding="10" FontSize="14" Margin="0,0,0,20"/>
                            
                            <Button Content="Login" Command="{Binding LoginWithPasswordCommand}"
                                    Background="#27AE60" Foreground="White" Padding="0,15" FontSize="16" FontWeight="Bold"
                                    BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </TabItem>

                    <!-- Biometric Login Tab -->
                    <TabItem Header="Fingerprint">
                        <StackPanel Margin="20" HorizontalAlignment="Center">
                            <TextBlock Text="👆" FontSize="72" HorizontalAlignment="Center" Margin="0,20,0,20"/>
                            <TextBlock Text="{Binding BiometricMessage}" FontSize="14" HorizontalAlignment="Center" 
                                       Foreground="#7F8C8D" Margin="0,0,0,20" TextWrapping="Wrap" TextAlignment="Center"/>
                            
                            <Button Content="Verify with Windows Hello" Command="{Binding LoginWithBiometricCommand}"
                                    Background="#3498DB" Foreground="White" Padding="20,15" FontSize="14" FontWeight="Bold"
                                    BorderThickness="0" Cursor="Hand" IsEnabled="{Binding IsBiometricAvailable}"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </Border>
    </Grid>
</Window>

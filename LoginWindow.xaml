<Window x:Class="EduSyncAI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EduSyncAI"
        Title="EduSync AI - Login" 
        Height="600" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <Style x:Key="PinButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Background="#ECF0F1">
        <!-- Header -->
        <Border Background="#2C3E50" Height="100" VerticalAlignment="Top">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🎓 EduSync AI" FontSize="32" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Lecturer Login" FontSize="14" 
                           Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Login Content -->
        <Border Background="White" Margin="30,120,30,30" CornerRadius="10" Padding="30">
            <StackPanel>
                <!-- Error Message -->
                <Border Background="#E74C3C" Padding="15" CornerRadius="5" Margin="0,0,0,20"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <!-- Single View with Toggle -->
                <Grid>
                    <!-- Username/Password Login Panel -->
                    <StackPanel x:Name="PasswordPanel" Margin="0,10,0,0" Visibility="Visible">
                        <TextBlock Text="Username:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Username}" Padding="10" FontSize="14" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Password:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="PasswordBox" Padding="10" FontSize="14" Margin="0,0,0,15"/>
                        
                        <Button Content="Login" Command="{Binding LoginWithPasswordCommand}"
                                Background="#27AE60" Foreground="White" Padding="0,15" FontSize="16" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,0,15"/>
                        
                        <Button Content="Login with Fingerprint 👆" Click="ToggleFingerprint_Click"
                                Background="Transparent" Foreground="#3498DB" FontSize="14" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Biometric Login Panel -->
                    <StackPanel x:Name="FingerprintPanel" Margin="0,10,0,0" Visibility="Collapsed" HorizontalAlignment="Center">
                        <TextBlock Text="👆" FontSize="72" HorizontalAlignment="Center" Margin="0,20,0,20"/>
                        <TextBlock Text="{Binding BiometricMessage}" FontSize="14" HorizontalAlignment="Center" 
                                   Foreground="#7F8C8D" Margin="0,0,0,20" TextWrapping="Wrap" TextAlignment="Center"/>
                        
                        <Button Content="Verify with Windows Hello" Command="{Binding LoginWithBiometricCommand}"
                                Background="#3498DB" Foreground="White" Padding="20,15" FontSize="14" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand" IsEnabled="{Binding IsBiometricAvailable}" Margin="0,0,0,15"/>
                                
                        <Button Content="Return to Password Login" Click="ToggleFingerprint_Click"
                                Background="Transparent" Foreground="#3498DB" FontSize="14" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
